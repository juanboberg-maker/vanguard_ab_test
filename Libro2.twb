      <column caption='Mediana time' datatype='real' name='[Calculation_0589341589110785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([time_spent_sec])' />
      </column>
      <column caption='Error rate %' datatype='real' name='[Calculation_0589341592608770]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Variation] : &#13;&#10;    COUNTD(IF [Calculation_0589341593878531] &gt; 1 AND [last_step] = &quot;confirm&quot; THEN [client_id] END) &#13;&#10;}&#13;&#10;/&#13;&#10;{ FIXED [Variation] : COUNTD(IF [last_step] = &quot;confirm&quot; THEN [client_id] END) } * 100' />
      </column>
      <column caption='Visitas por paso' datatype='integer' name='[Calculation_0589341593878531]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [client_id], [process_step] : COUNT([client_id]) }' />
      </column>
      <column caption='Clientes únicos ' datatype='integer' name='[Calculation_0589341595820036]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([client_id])' />
      </column>
      <column caption='Cálculo1' datatype='integer' name='[Calculation_1997540752760838]' role='measure' type='quantitative'>
